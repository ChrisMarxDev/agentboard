---
const steps = [
  {
    n: "01",
    title: "Install in one line",
    body: "Detects your platform, downloads the binary, installs the Claude skill, wires the MCP server. No Homebrew, no Docker, no config.",
    code: "$ curl -fsSL https://agentboard.dev/install.sh | sh",
  },
  {
    n: "02",
    title: "Ask Claude to start it",
    body: 'Open Claude Desktop or Claude Code and say "start AgentBoard." The skill handles the rest.',
    code: "> start AgentBoard",
  },
  {
    n: "03",
    title: "Watch it come alive",
    body: "Your browser opens to a live dashboard. Claude seeds a welcome page and demonstrates a realtime update. From here, every agent write lands in the UI.",
    code: "✓ AgentBoard live at http://localhost:3000",
  },
];
---

<section id="how-it-works" class="relative py-24 sm:py-32">
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"
    aria-hidden="true"
  >
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-2xl">
      <p class="text-sm font-medium text-zinc-500">How it works</p>
      <h2
        class="mt-2 text-3xl font-semibold tracking-tight text-white sm:text-4xl"
      >
        One line, one sentence, one live dashboard.
      </h2>
      <p class="mt-4 text-lg text-zinc-400">
        You don't open a config file. You don't pick a port. You don't read
        docs to get your first dashboard.
      </p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {
        steps.map((s) => (
          <div class="relative rounded-xl border border-white/10 bg-white/[0.02] p-6 transition hover:border-white/20">
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs text-zinc-500">{s.n}</span>
              <span class="h-px flex-1 bg-white/5" />
            </div>
            <h3 class="mt-4 text-lg font-semibold text-white">{s.title}</h3>
            <p class="mt-2 text-sm text-zinc-400">{s.body}</p>
            <pre class="mt-5 overflow-x-auto rounded-md border border-white/5 bg-black/50 px-3 py-2.5 font-mono text-[12px] leading-5 text-zinc-300"><code>{s.code}</code></pre>
          </div>
        ))
      }
    </div>

    <div class="mt-16 rounded-xl border border-white/10 bg-gradient-to-br from-white/[0.03] to-transparent p-10 text-center">
      <h3 class="text-2xl font-semibold text-white sm:text-3xl">
        Ready in sixty seconds.
      </h3>
      <p class="mx-auto mt-3 max-w-lg text-zinc-400">
        Paste the installer. Ask Claude. You're done.
      </p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        <a
          href="#install"
          class="inline-flex h-11 items-center rounded-md bg-white px-5 text-sm font-medium text-black transition hover:bg-zinc-200"
        >
          Install now
        </a>
        <a
          href="https://github.com/anthropics"
          class="inline-flex h-11 items-center rounded-md border border-white/10 bg-white/[0.02] px-5 text-sm font-medium text-white transition hover:border-white/20 hover:bg-white/[0.04]"
        >
          Read the docs
        </a>
      </div>
    </div>
  </div>
</section>

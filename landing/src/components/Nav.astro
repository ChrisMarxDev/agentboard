---
const links = [
  { href: "#features", label: "Why" },
  { href: "#use-cases", label: "Use cases" },
  { href: "#how-it-works", label: "How it works" },
  { href: "#faq", label: "FAQ" },
];
---

<header
  class="sticky top-0 z-50 border-b border-white/5 bg-[#0a0a0a]/70 backdrop-blur-md"
>
  <div
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6"
  >
    <a href="/" class="flex items-center gap-2.5 font-semibold tracking-tight">
      <span
        class="grid h-7 w-7 grid-cols-2 grid-rows-2 gap-[2px] rounded-[5px] bg-white/5 p-[3px]"
        aria-hidden="true"
      >
        <span class="rounded-[1px] bg-blue-400"></span>
        <span class="rounded-[1px] bg-violet-400"></span>
        <span class="rounded-[1px] bg-emerald-400"></span>
        <span class="rounded-[1px] bg-amber-400"></span>
      </span>
      <span class="text-white">AgentBoard</span>
    </a>

    <nav class="hidden items-center gap-8 text-sm text-zinc-400 md:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="transition-colors hover:text-white"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="https://github.com/anthropics"
        class="hidden text-sm text-zinc-400 transition-colors hover:text-white sm:inline"
      >
        GitHub
      </a>
      <a
        href="#install"
        class="inline-flex h-9 items-center rounded-md bg-white px-4 text-sm font-medium text-black transition hover:bg-zinc-200"
      >
        Install
      </a>
    </div>
  </div>
</header>

---
const features = [
  {
    title: "You describe it. Claude builds it.",
    body: 'Say "add a page tracking my morning runs." Claude writes the page, wires up the data, and opens it in your browser. No YAML, no drag-and-drop, no config file.',
    accent: "text-blue-400",
  },
  {
    title: "Built for Claude from day one",
    body: "13 MCP tools ship in the box. Claude Desktop and Claude Code pick them up automatically after install — no glue code, no OAuth dance, no plugin marketplace to browse.",
    accent: "text-violet-400",
  },
  {
    title: "Live by default",
    body: "Every write fans out to every open tab in milliseconds. Your agent logs something on one side of the laptop, and the chart on the other side moves.",
    accent: "text-emerald-400",
  },
  {
    title: "Private by default",
    body: "AgentBoard runs on localhost. Your data lives in one file on your disk. Nothing ever leaves your laptop — no telemetry, no cloud, no signup.",
    accent: "text-amber-400",
  },
  {
    title: "One sentence to install. One to start.",
    body: 'Paste the installer, then tell Claude "start AgentBoard." That\'s the entire setup. No ports to pick, no config to edit, no docs to read first.',
    accent: "text-rose-400",
  },
  {
    title: "Free. Open source. Yours.",
    body: "MIT licensed. Read the code, fork it, self-host it for your team, or contribute back. No paid tier waiting around the corner.",
    accent: "text-cyan-400",
  },
];
---

<section id="features" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-2xl">
      <p class="text-sm font-medium text-zinc-500">Why it's different</p>
      <h2
        class="mt-2 text-3xl font-semibold tracking-tight text-white sm:text-4xl"
      >
        The dashboard that lives inside your Claude session.
      </h2>
      <p class="mt-4 text-lg text-zinc-400">
        Most dashboards were built for humans clicking buttons. AgentBoard is
        built for agents and the people who talk to them.
      </p>
    </div>

    <div class="mt-16 grid gap-px overflow-hidden rounded-xl border border-white/10 bg-white/5 md:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <div class="group relative bg-[#0a0a0a] p-8 transition-colors hover:bg-[#0d0d10]">
            <div class={`font-mono text-xs uppercase tracking-wider ${f.accent}`}>
              ◆
            </div>
            <h3 class="mt-4 text-lg font-semibold text-white">{f.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-zinc-400">{f.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

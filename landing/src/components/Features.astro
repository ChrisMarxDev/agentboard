---
const features = [
  {
    title: "Single binary",
    body: "One Go executable. No Docker, no Postgres, no Redis. Ship it on your laptop, a VM, a Raspberry Pi — anywhere.",
    accent: "text-blue-400",
  },
  {
    title: "MCP-native",
    body: "13 MCP tools built in. Claude and other agents can write data, author pages, and list components without glue code.",
    accent: "text-violet-400",
  },
  {
    title: "Live by default",
    body: "Every write fans out over SSE. Connected browsers update instantly — no polling, no refresh button.",
    accent: "text-emerald-400",
  },
  {
    title: "9 built-in components",
    body: "Metric, Chart, TimeSeries, Table, Kanban, List, Log, Status, Progress. Drop them into a page and they bind to your data.",
    accent: "text-amber-400",
  },
  {
    title: "MDX pages",
    body: "Author dashboards in Markdown with React components inline. Files on disk, compiled client-side. No build step required.",
    accent: "text-rose-400",
  },
  {
    title: "SQLite storage",
    body: "Durable. One file. Back it up with cp. No migrations, no connection pools, no ops budget.",
    accent: "text-cyan-400",
  },
];
---

<section id="features" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-2xl">
      <p class="text-sm font-medium text-zinc-500">Features</p>
      <h2
        class="mt-2 text-3xl font-semibold tracking-tight text-white sm:text-4xl"
      >
        Built for the agent loop.
      </h2>
      <p class="mt-4 text-lg text-zinc-400">
        AgentBoard stays out of the way. Agents write, humans watch. That's
        the whole API surface.
      </p>
    </div>

    <div class="mt-16 grid gap-px overflow-hidden rounded-xl border border-white/10 bg-white/5 md:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <div class="group relative bg-[#0a0a0a] p-8 transition-colors hover:bg-[#0d0d10]">
            <div class={`font-mono text-xs uppercase tracking-wider ${f.accent}`}>
              ◆
            </div>
            <h3 class="mt-4 text-lg font-semibold text-white">{f.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-zinc-400">{f.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

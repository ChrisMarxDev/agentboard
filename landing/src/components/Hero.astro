---
const installCmd = "curl -fsSL https://agentboard.dev/install.sh | sh";
---

<section class="relative isolate overflow-hidden">
  <div class="bg-grid bg-grid-mask absolute inset-0 -z-10"></div>
  <div
    class="absolute inset-x-0 top-[-10%] -z-10 h-[500px] bg-[radial-gradient(ellipse_50%_50%_at_50%_50%,rgba(96,165,250,0.12),transparent_70%)]"
  >
  </div>

  <div class="mx-auto max-w-6xl px-6 pt-24 pb-20 sm:pt-32 sm:pb-28">
    <div class="grid items-center gap-16 lg:grid-cols-[1.05fr_1fr]">
      <div class="max-w-2xl">
        <a
          href="https://github.com/anthropics"
          class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1 text-xs text-zinc-400 transition hover:border-white/20 hover:text-white"
        >
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-emerald-400"
          ></span>
          v0.1 · Open source · One-line install
          <span aria-hidden="true" class="text-zinc-600">→</span>
        </a>

        <h1
          class="mt-6 text-5xl leading-[1.05] font-semibold tracking-tight text-white sm:text-6xl"
        >
          Dashboards your agents
          <span class="text-gradient">can write to.</span>
        </h1>

        <p class="mt-6 max-w-xl text-lg leading-relaxed text-zinc-400">
          Install in one line. Tell Claude to start it. A live dashboard
          opens in your browser — ready for your agents to write to.
          Runs entirely on your laptop.
        </p>

        <!-- Install command block — the primary CTA -->
        <div id="install" class="mt-8">
          <label class="text-xs text-zinc-500 font-mono tracking-wide uppercase">
            1. Paste into your terminal
          </label>
          <div
            class="mt-2 flex items-center gap-2 rounded-lg border border-white/10 bg-[#0d0d10] px-4 py-3 font-mono text-sm text-zinc-200 shadow-[0_0_0_1px_rgba(255,255,255,0.02)]"
          >
            <span class="text-zinc-600 select-none">$</span>
            <code
              id="install-cmd"
              class="flex-1 overflow-x-auto whitespace-nowrap"
              >{installCmd}</code
            >
            <button
              type="button"
              data-copy-target="install-cmd"
              class="shrink-0 rounded-md border border-white/10 bg-white/5 px-2.5 py-1 text-xs text-zinc-300 transition hover:border-white/20 hover:bg-white/10 hover:text-white"
              aria-label="Copy install command"
            >
              <span data-copy-label>Copy</span>
            </button>
          </div>
          <p class="mt-3 text-sm text-zinc-500">
            <span class="text-zinc-400 font-mono">2.</span>
             Open Claude and say <span
              class="rounded bg-white/5 px-1.5 py-0.5 font-mono text-zinc-200"
              >start AgentBoard</span
            >.
          </p>
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href="https://github.com/anthropics"
            class="inline-flex h-10 items-center gap-2 rounded-md border border-white/10 bg-white/[0.02] px-4 text-sm font-medium text-white transition hover:border-white/20 hover:bg-white/[0.04]"
          >
            <svg
              viewBox="0 0 24 24"
              aria-hidden="true"
              class="h-4 w-4 fill-current"
            >
              <path
                d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.52-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.17 1.18a11 11 0 0 1 5.78 0c2.2-1.49 3.17-1.18 3.17-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.41-5.25 5.69.41.35.77 1.04.77 2.1v3.12c0 .31.2.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"
              ></path>
            </svg>
            View on GitHub
          </a>
          <a
            href="#how-it-works"
            class="inline-flex h-10 items-center text-sm font-medium text-zinc-400 transition hover:text-white"
          >
            How it works →
          </a>
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-zinc-500">
          <span class="inline-flex items-center gap-1.5">
            <span class="h-1 w-1 rounded-full bg-zinc-600"></span>
            No account
          </span>
          <span class="inline-flex items-center gap-1.5">
            <span class="h-1 w-1 rounded-full bg-zinc-600"></span>
            No cloud
          </span>
          <span class="inline-flex items-center gap-1.5">
            <span class="h-1 w-1 rounded-full bg-zinc-600"></span>
            macOS & Linux
          </span>
          <span class="inline-flex items-center gap-1.5">
            <span class="h-1 w-1 rounded-full bg-zinc-600"></span>
            MIT licensed
          </span>
        </div>
      </div>

      <!-- Right-hand "what happens next" card -->
      <div class="relative">
        <div
          class="absolute -inset-px rounded-xl bg-gradient-to-br from-blue-500/20 via-violet-500/10 to-transparent blur-sm"
          aria-hidden="true"
        >
        </div>
        <div
          class="relative overflow-hidden rounded-xl border border-white/10 bg-[#0d0d10] shadow-[0_0_0_1px_rgba(255,255,255,0.02),0_20px_40px_-20px_rgba(0,0,0,0.6)]"
        >
          <div
            class="flex items-center gap-2 border-b border-white/5 px-4 py-2.5"
          >
            <span class="h-2.5 w-2.5 rounded-full bg-white/10"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-white/10"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-white/10"></span>
            <span class="ml-2 font-mono text-[11px] text-zinc-500">
              Claude · you
            </span>
          </div>
          <div class="px-5 py-5 font-mono text-[13px] leading-6">
            <p class="text-zinc-500">&gt; start AgentBoard</p>
            <p class="mt-4 text-zinc-300">
              <span class="text-emerald-400">✓</span>
              <span class="text-zinc-400">Binary found at</span>
              <span class="text-white">~/.agentboard/bin/agentboard</span>
            </p>
            <p class="mt-1 text-zinc-300">
              <span class="text-emerald-400">✓</span>
              <span class="text-zinc-400">Server listening on</span>
              <span class="text-white">:3000</span>
            </p>
            <p class="mt-1 text-zinc-300">
              <span class="text-emerald-400">✓</span>
              <span class="text-zinc-400">Opened</span>
              <span class="text-blue-300 underline underline-offset-2">http://localhost:3000</span>
            </p>
            <p class="mt-4 text-zinc-300">
              Your AgentBoard is live. Seeded a welcome page with a live
              counter and log. Try:
              <span class="text-white">"write 'hello' to the log"</span>
              and watch the dashboard update.
            </p>
            <p class="mt-5 flex items-center gap-2 text-zinc-500">
              &gt;
              <span
                class="inline-block h-4 w-2 bg-zinc-500 align-middle [animation:cursor-blink_1s_steps(1)_infinite]"
              ></span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const buttons = document.querySelectorAll("[data-copy-target]");
    buttons.forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-copy-target");
        const target = id && document.getElementById(id);
        if (!target) return;
        const text = (target.textContent || "").trim();
        const label = btn.querySelector("[data-copy-label]");
        try {
          await navigator.clipboard.writeText(text);
          if (label) {
            const prev = label.textContent;
            label.textContent = "Copied";
            btn.classList.add("!border-emerald-400/30", "!text-emerald-300");
            setTimeout(() => {
              label.textContent = prev || "Copy";
              btn.classList.remove(
                "!border-emerald-400/30",
                "!text-emerald-300",
              );
            }, 1500);
          }
        } catch (err) {
          if (label) label.textContent = "Copy failed";
        }
      });
    });
  })();
</script>

<style>
  @keyframes cursor-blink {
    50% {
      opacity: 0;
    }
  }
</style>

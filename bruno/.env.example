# Copy this file to `bruno/.env` and fill in your values.
# `.env` is gitignored so your hosted-instance identity and secrets stay out
# of the public repo. Bruno auto-loads this file for both the GUI and the
# `bru run` CLI, exposing values as `{{process.env.VAR}}`.

# Public URL of your hosted AgentBoard instance (no trailing slash).
AGENTBOARD_URL=https://your-app.fly.dev

# Bearer/Basic token configured on the hosted AgentBoard instance
# (set via `fly secrets set AGENTBOARD_AUTH_TOKEN=...`).
AGENTBOARD_AUTH_TOKEN=paste-your-fly-auth-token-here
